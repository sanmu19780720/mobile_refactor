# 数据库连接
DB_HOST=<your-db-host>
DB_PORT=3306
DB_NAME=<your-db-name>
DB_USER=<your-db-user>
DB_PASS=<your-db-password>

# JWT 配置（生产环境务必换成长随机串）
JWT_SECRET=<random-secret-at-least-32-chars>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# CORS 允许的前端来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PC 端 ERP 地址和账号（用于代理拉取合同预览 PDF）
PC_BASE_URL=<pc-erp-base-url>
PC_USER=<pc-erp-username>
PC_PWD=<pc-erp-password>

# 本地账号（JSON 数组：用户名/bcrypt哈希/真实姓名/角色）
# 用 python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())" 生成哈希
LOCAL_USERS_JSON=[["your_username","$2b$12$<your-bcrypt-hash>","真实姓名","admin"]]
